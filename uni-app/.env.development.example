# 复制为 .env.development
#
# H5 开发：/api，由 vite.config.js 代理到 http://localhost:8091
# 微信小程序：须完整 http(s) 地址，例如 http://localhost:8091/api 或 https://域名/api（勿用 /api）

VITE_API_BASE_URL=/api

# 可选：WebSocket 直连（H5 代理 WS 异常时使用）
# VITE_RUNNER_WS_BASE=ws://localhost:8091/api

# --- 小程序本地联调示例（取消注释并改成你的测试域名）---
# VITE_API_BASE_URL=https://test-runner.example.com/api
# VITE_RUNNER_WS_BASE=wss://test-runner.example.com/api